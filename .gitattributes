# Normalisasi line-ending. Source .NET/Windows pakai CRLF; teks lain LF.
* text=auto

*.vb       text eol=crlf
*.vbproj   text eol=crlf
*.sln      text eol=crlf merge=binary
*.config   text eol=crlf
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf
*.resx     text eol=crlf

*.json     text eol=lf
*.md       text eol=lf
*.sh       text eol=lf

# Binary
*.pdf      binary
*.png      binary
